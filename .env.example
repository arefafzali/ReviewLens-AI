# Shared local development defaults for docker-compose
POSTGRES_DB=reviewlens
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

REVIEWLENS_ENVIRONMENT=local
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Firecrawl provider config (only active fetch provider currently)
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
REVIEWLENS_OPENAI_MODEL=gpt-4o-mini
REVIEWLENS_FIRECRAWL_TIMEOUT_SECONDS=45
REVIEWLENS_OPENAI_TIMEOUT_SECONDS=45
REVIEWLENS_MARKDOWN_CHUNK_SIZE_CHARS=6000
REVIEWLENS_MARKDOWN_CHUNK_OVERLAP_CHARS=800
REVIEWLENS_MARKDOWN_MAX_CHUNKS=30

# Workspace isolation cookie settings
REVIEWLENS_WORKSPACE_COOKIE_NAME=reviewlens_workspace_id
REVIEWLENS_WORKSPACE_COOKIE_MAX_AGE_SECONDS=2592000
REVIEWLENS_WORKSPACE_COOKIE_SECURE=false
REVIEWLENS_WORKSPACE_COOKIE_HTTP_ONLY=true
REVIEWLENS_WORKSPACE_COOKIE_SAME_SITE=lax
REVIEWLENS_WORKSPACE_COOKIE_PATH=/

# Optional: enables Postgres retrieval parity integration test when set.
# Example: postgresql+psycopg://postgres:postgres@localhost:5432/reviewlens
REVIEWLENS_POSTGRES_TEST_URL=

REVIEWLENS_CORS_ALLOW_ORIGINS=http://localhost:3000

# Production guidance:
# - Set REVIEWLENS_ENVIRONMENT=production
# - Set REVIEWLENS_CORS_ALLOW_ORIGINS to your frontend public URL(s)
# - Keep REVIEWLENS_WORKSPACE_COOKIE_SECURE=true and SAME_SITE=none for cross-site HTTPS
